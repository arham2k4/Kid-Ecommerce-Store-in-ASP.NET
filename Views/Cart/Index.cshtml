@model IEnumerable<ECommerceMVC.Models.CartItem>

<h2>Shopping Cart</h2>

<table class="table">

<tr>
<th>Product Id</th>
<th>Quantity</th>
<th></th>
</tr>

@foreach(var item in Model)
{
<tr>

<td>@item.ProductId</td>

<td>@item.Quantity</td>

<td>

<a href="/Cart/Remove/@item.Id"
class="btn btn-danger">

Remove

</a>

</td>

</tr>
}

</table>